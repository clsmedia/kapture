# HTTPS is MANDATORY in production. Basic Auth transmits
# the password as base64-encoded plaintext over the wire.
ADMIN_PASSWORD=changeme
LOG_DIR=./logs
ROTATE_DAYS=7

# Set to 'sqlite' to store in SQLite database (requires ext-sqlite3)
# STORAGE_DRIVER=filesystem

# When set, every captured request is forwarded to this URL.
# The captured path is appended (e.g. /kapture/test → http://localhost:3000/test).
# The target's response (status + headers + body) is returned to the sender.
# FORWARD_URL=http://localhost:3000
